# Карта сетей для авто-режима (vpn-autonet.sh).
# Скопируй в ~/.config/vpn/netmap и впиши свои сети.
#
# Формат:  <идентификатор>  <режим>
#   идентификатор — SSID Wi-Fi ИЛИ MAC шлюза по умолчанию
#                   (узнать: bash scripts/vpn-autonet.sh whoami)
#   режим         — full (весь трафик через Латвию) | selective (только сервисы)
#
# Сопоставление идёт сверху вниз; первая совпавшая строка побеждает.
# Строка default задаёт режим для всех несовпавших (неизвестных) сетей.

# Домашняя сеть по MAC роутера → весь трафик
a4:b1:c1:d2:e3:f4   full

# Домашний Wi-Fi по имени → весь трафик
MyHomeWiFi          full

# Рабочая сеть → только сервисы
Office-WiFi         selective

# Все остальные/неизвестные сети → весь трафик через Латвию (безопасный дефолт:
# не «роняет» в RU на незнакомых сетях). Поменяй на selective, если хочешь иначе.
default             full
