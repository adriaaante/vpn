{
  "log": {
    "level": "error",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "type": "https",
        "tag": "dns-remote",
        "server": "1.1.1.1",
        "detour": "proxy"
      },
      {
        "type": "local",
        "tag": "dns-local"
      }
    ],
    "rules": [
      {
        "domain_suffix": [".ru", ".рф", "mail.ru", "yandex.net", "vk.com", "vkontakte.ru", "sberbank.ru", "gosuslugi.ru"],
        "server": "dns-local"
      }
    ],
    "strategy": "ipv4_only",
    "independent_cache": true,
    "final": "dns-remote"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": ["172.19.0.1/30", "fdfe:dcba:9876::1/126"],
      "auto_route": true,
      "strict_route": true,
      "stack": "system"
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "proxy",
      "outbounds": ["auto", "vless-reality", "hysteria2"],
      "default": "auto"
    },
    {
      "type": "urltest",
      "tag": "auto",
      "outbounds": ["vless-reality", "hysteria2"],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "3m",
      "tolerance": 50,
      "interrupt_exist_connections": false
    },
    {
      "type": "vless",
      "tag": "vless-reality",
      "server": "__SERVER_IP__",
      "server_port": 443,
      "uuid": "__VLESS_UUID__",
      "flow": "xtls-rprx-vision",
      "tls": {
        "enabled": true,
        "server_name": "__REALITY_SNI__",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "__REALITY_PUBLIC_KEY__",
          "short_id": "__REALITY_SHORT_ID__"
        }
      }
    },
    {
      "type": "hysteria2",
      "tag": "hysteria2",
      "server": "__SERVER_IP__",
      "server_port": 443,
      "password": "__HYSTERIA2_PASSWORD__",
      "tls": {
        "enabled": true,
        "server_name": "__SERVER_IP__",
        "insecure": true,
        "alpn": ["h3"]
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "default_domain_resolver": "dns-local",
    "rules": [
      { "action": "sniff" },
      { "protocol": "dns", "action": "hijack-dns" },
      { "ip_is_private": true, "outbound": "direct" },
      {
        "domain_suffix": [".ru", ".рф", "mail.ru", "yandex.net", "vk.com", "vkontakte.ru", "sberbank.ru", "gosuslugi.ru"],
        "outbound": "direct"
      },
      {
        "ip_cidr": ["91.108.4.0/22", "91.108.8.0/22", "91.108.12.0/22", "91.108.16.0/22", "91.108.20.0/22", "91.108.56.0/22", "95.161.64.0/20", "149.154.160.0/20", "185.76.151.0/24", "2001:b28:f23d::/48", "2001:b28:f23f::/48", "2001:67c:4e8::/48"],
        "outbound": "proxy"
      },
      { "rule_set": "geoip-ru", "outbound": "direct" },
      {
        "domain_suffix": [
          "claude.ai", "anthropic.com", "claude.com",
          "openai.com", "chatgpt.com", "oaistatic.com", "oaiusercontent.com",
          "youtube.com", "youtu.be", "googlevideo.com", "ytimg.com", "ggpht.com",
          "telegram.org", "t.me", "telegram.me", "telesco.pe"
        ],
        "outbound": "proxy"
      }
    ],
    "rule_set": [
      {
        "type": "remote",
        "tag": "geoip-ru",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-ru.srs",
        "download_detour": "proxy"
      }
    ],
    "final": "proxy",
    "auto_detect_interface": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "/etc/sing-box/cache.db"
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "secret": "__CLASH_SECRET__"
    }
  }
}
