# Локальные конфиги с реальными ключами/секретами — НИКОГДА не коммитим
*.local.json
configs/*.local.json
secrets/
credentials.txt

# Бэкапы локальных конфигов (upgrade-client.sh: *.local.json.bak.<время>) —
# тоже содержат секреты, не коммитим
*.bak
*.bak.*

# Сертификаты/ключи
*.pem
*.key

# Локальные артефакты рантайма (не коммитим)
*.pf.conf
killswitch.enabled
cache.db

# Прочее
.DS_Store
*.log
